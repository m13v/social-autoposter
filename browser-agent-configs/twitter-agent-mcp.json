{
  "mcpServers": {
    "twitter-agent": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--config",
        "__HOME__/.claude/browser-agent-configs/twitter-agent.json"
      ],
      "env": {
        "PATH": "__NODE_BIN__:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  }
}
